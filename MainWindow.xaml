<Window x:Class="ClaudeWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClaudeWidget"
        Title="Claude Widget"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        Topmost="True">

    <Border x:Name="Root"
            CornerRadius="16"
            Width="300"
            BorderBrush="#2EFFFFFF"
            BorderThickness="1"
            MouseLeftButtonDown="Root_MouseLeftButtonDown">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#F51C1C22" Offset="0"/>
                <GradientStop Color="#F5141418" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect BlurRadius="22" ShadowDepth="4" Opacity="0.55" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <StackPanel Margin="16,12,16,14">

                <!-- Cabecera: Claude | Automático + flechas | ajustes/ocultar -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot" Width="9" Height="9" Fill="#4ADE80" Margin="0,0,7,0"/>
                        <TextBlock Text="Claude" Foreground="White" FontSize="14" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock Text="Auto" Foreground="#D8D8E0" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <ToggleButton x:Name="FreeToggle" Click="FreeMode_Click" Style="{StaticResource Switch}"
                                      VerticalAlignment="Center"
                                      ToolTip="Aceptar/denegar automáticamente todas las peticiones (haz lo que quieras), salvo la lista negra"/>
                        <Button x:Name="PrevBtn" Content="&#x25C0;" Click="PrevPage_Click"
                                Margin="6,0,0,0" Style="{StaticResource IconButton}" ToolTip="Cambiar pantalla"/>
                        <Button x:Name="NextBtn" Content="&#x25B6;" Click="NextPage_Click"
                                Style="{StaticResource IconButton}" ToolTip="Cambiar pantalla"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="SettingsBtn" Content="&#x2699;" Click="SettingsBtn_Click"
                                ToolTip="Ajustes" Style="{StaticResource IconButton}"/>
                        <Button x:Name="HideBtn" Content="&#x2715;" Click="HideBtn_Click"
                                ToolTip="Ocultar" Style="{StaticResource IconButton}"/>
                    </StackPanel>
                </Grid>

                <!-- Aviso de permiso pendiente (se muestra solo cuando esperas validación) -->
                <Border x:Name="PendingPanel" Visibility="Collapsed" CornerRadius="10"
                        Background="#33F87171" BorderBrush="#88F87171" BorderThickness="1"
                        Margin="0,8,0,2" Padding="10,8">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="⏳ Esperando tu validación" Foreground="#FFD7D7" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Button Content="&#x2715;" Click="DismissPending_Click" HorizontalAlignment="Right"
                                    ToolTip="Descartar aviso (no responde)" Style="{StaticResource IconButton}"/>
                        </Grid>
                        <TextBlock x:Name="PendingTitle" Text="" Foreground="White" FontSize="12" FontWeight="SemiBold" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        <TextBlock x:Name="PendingMsg" Text="" Foreground="#C8C8D0" FontSize="11" Margin="0,2,0,8" TextWrapping="Wrap" MaxHeight="60"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" x:Name="ApproveBtn" Content="✓ Aprobar" Click="Approve_Click"
                                    Background="#FF22A06B" Style="{StaticResource ActionButton}"/>
                            <Button Grid.Column="2" x:Name="DenyBtn" Content="✕ Denegar" Click="Deny_Click"
                                    Background="#FFC0392B" Style="{StaticResource ActionButton}"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ============ PANTALLA 1: bicho + barras ============ -->
                <StackPanel x:Name="Page1">
                    <local:Critter x:Name="Critter" HorizontalAlignment="Center" Margin="0,6,0,0"
                                   MouseRightButtonUp="Critter_MouseRightButtonUp"
                                   ToolTip="Click derecho: ver todas las animaciones seguidas"/>
                    <TextBlock x:Name="MoodText" Text="" HorizontalAlignment="Center"
                               Foreground="#90FFFFFF" FontSize="10" Margin="0,0,0,2"/>

                    <StackPanel x:Name="SummaryPanel" Margin="0,8,0,0"/>
                </StackPanel>

                <!-- ============ PANTALLA 2: detalles ============ -->
                <StackPanel x:Name="Page2" Visibility="Collapsed">
                    <StackPanel x:Name="MetricsPanel" Margin="0,4,0,0"/>
                    <TextBlock x:Name="FooterText" Text="—" Foreground="#70FFFFFF"
                               FontSize="10" Margin="0,10,0,0" TextWrapping="Wrap"/>
                </StackPanel>

            </StackPanel>

            <!-- Overlay de parpadeo (aviso) -->
            <Border x:Name="AlertOverlay" CornerRadius="16" BorderBrush="#F87171" BorderThickness="3"
                    Background="#22F87171" IsHitTestVisible="False" Opacity="0"/>
        </Grid>
    </Border>
</Window>
