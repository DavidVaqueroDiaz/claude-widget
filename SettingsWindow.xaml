<Window x:Class="ClaudeWidget.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ajustes"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen">
    <Border CornerRadius="14" Width="330" Background="#FF1C1C22"
            BorderBrush="#33FFFFFF" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.5"/>
        </Border.Effect>
        <StackPanel Margin="18,14,18,16">

            <Grid Margin="0,0,0,8">
                <TextBlock Text="Ajustes del widget" Foreground="White" FontSize="15" FontWeight="Bold"/>
                <Button Content="&#x2715;" Click="Cancel_Click" HorizontalAlignment="Right"
                        Style="{StaticResource IconButton}"/>
            </Grid>

            <ScrollViewer MaxHeight="430" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock Text="Consumo del plan" Foreground="#9AA0FF" FontSize="11" FontWeight="SemiBold" Margin="0,4,0,4"/>
                    <CheckBox x:Name="CkPlanApi" Content="% exacto del plan (usa tu token; endpoint no oficial)" Foreground="White" Margin="0,2"/>
                    <TextBlock Text="Si lo desactivas, solo se muestran tokens/coste de ccusage (100% limpio)." Foreground="#80FFFFFF" FontSize="10" Margin="0,0,0,8" TextWrapping="Wrap"/>

                    <TextBlock Text="Reinicio del límite semanal" Foreground="#9AA0FF" FontSize="11" FontWeight="SemiBold" Margin="0,4,0,4"/>
                    <TextBlock Text="(día y hora que ves en /usage; el contador será exacto)" Foreground="#80FFFFFF" FontSize="10" Margin="0,0,0,4" TextWrapping="Wrap"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="WeekDayBox" Grid.Column="0" Padding="6,3">
                            <ComboBoxItem Content="Lunes"/>
                            <ComboBoxItem Content="Martes"/>
                            <ComboBoxItem Content="Miércoles"/>
                            <ComboBoxItem Content="Jueves"/>
                            <ComboBoxItem Content="Viernes"/>
                            <ComboBoxItem Content="Sábado"/>
                            <ComboBoxItem Content="Domingo"/>
                        </ComboBox>
                        <TextBox x:Name="WeekTimeBox" Grid.Column="2" Padding="6,4" FontSize="13"
                                 Background="#FF2A2A33" Foreground="White" BorderBrush="#44FFFFFF" ToolTip="HH:MM"/>
                    </Grid>

                    <TextBlock Text="Pantalla «Detalles»" Foreground="#9AA0FF" FontSize="11" FontWeight="SemiBold" Margin="0,10,0,4"/>
                    <CheckBox x:Name="CkModel" Content="Modelo" Foreground="White" Margin="0,2"/>
                    <CheckBox x:Name="CkTodayTokens" Content="Hoy (tokens)" Foreground="White" Margin="0,2"/>
                    <CheckBox x:Name="CkTodayCost" Content="Hoy (≈$)" Foreground="White" Margin="0,2"/>
                    <CheckBox x:Name="CkMonthCost" Content="Mes (≈$)" Foreground="White" Margin="0,2"/>
                    <CheckBox x:Name="CkBlockWindow" Content="Sesión 5h (tokens·$)" Foreground="White" Margin="0,2"/>
                    <CheckBox x:Name="CkBurnRate" Content="Ritmo (tokens/min)" Foreground="White" Margin="0,2"/>
                    <CheckBox x:Name="CkProjection" Content="Tiempo restante de sesión" Foreground="White" Margin="0,2"/>

                    <TextBlock Text="Ventana y avisos" Foreground="#9AA0FF" FontSize="11" FontWeight="SemiBold" Margin="0,10,0,4"/>
                    <CheckBox x:Name="CkStartWin" Content="Arrancar al iniciar Windows" Foreground="White" Margin="0,2"/>
                    <CheckBox x:Name="CkLinkClaude" Content="Mostrar solo cuando Claude está abierto" Foreground="White" Margin="0,2"/>
                    <CheckBox x:Name="CkOnTop" Content="Siempre visible (always on top)" Foreground="White" Margin="0,2"/>
                    <CheckBox x:Name="CkBlink" Content="Parpadear al esperar validación" Foreground="White" Margin="0,2"/>
                    <CheckBox x:Name="CkSound" Content="Sonar al esperar validación" Foreground="White" Margin="0,2"/>

                    <TextBlock Text="Plan" Foreground="#9AA0FF" FontSize="11" FontWeight="SemiBold" Margin="0,10,0,4"/>
                    <ComboBox x:Name="CmbPlan" Margin="0,2" Padding="6,3">
                        <ComboBoxItem Content="Max 20x"/>
                        <ComboBoxItem Content="Max 5x"/>
                        <ComboBoxItem Content="Pro"/>
                        <ComboBoxItem Content="Otro"/>
                    </ComboBox>

                    <TextBlock Text="Refrescar consumo cada (segundos)" Foreground="#9AA0FF" FontSize="11" FontWeight="SemiBold" Margin="0,10,0,4"/>
                    <TextBox x:Name="TxtRefresh" Padding="6,4" FontSize="13"
                             Background="#FF2A2A33" Foreground="White" BorderBrush="#44FFFFFF"/>
                </StackPanel>
            </ScrollViewer>

            <Grid Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Cancelar" Click="Cancel_Click"
                        Background="#FF3A3A44" Style="{StaticResource ActionButton}"/>
                <Button Grid.Column="2" Content="Guardar" Click="Save_Click"
                        Background="#FF4F7DF0" Style="{StaticResource ActionButton}"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
